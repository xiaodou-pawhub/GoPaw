# ===========================================================================
# GoPaw 启动配置示例
# 复制此文件为 config.yaml，按需修改后启动服务。
#
# ⚠️  此文件只包含【系统启动配置】，不需要填写任何 API Key。
#     LLM 提供商、频道密钥、Agent 设定均通过 Web UI 配置（存储在 SQLite）。
# ===========================================================================

# ---------------------------------------------------------------------------
# 工作区目录
# 所有运行时数据（数据库、日志、Agent 文件）都存放在此目录下。
# ---------------------------------------------------------------------------
workspace:
  dir: ~/.gopaw   # 支持 ~ 展开；也可用相对路径如 ./data

# ---------------------------------------------------------------------------
# 基础设置
# ---------------------------------------------------------------------------
app:
  name: "GoPaw"
  language: zh
  timezone: Asia/Shanghai
  debug: false

# ---------------------------------------------------------------------------
# HTTP 服务器
# ---------------------------------------------------------------------------
server:
  host: 0.0.0.0
  port: 8088

# ---------------------------------------------------------------------------
# Agent 行为参数
# Agent 的 System Prompt（角色设定）通过 Web UI → 设置 → Agent 配置
# ---------------------------------------------------------------------------
agent:
  max_steps: 20       # ReAct 循环最大步数（防止死循环）
  memory:
    context_limit: 4000   # Session 内估算 token 超过此值时触发记忆压缩
    history_limit: 50     # 每次调用最多取最近多少条消息作为上下文

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------
log:
  level: info          # debug / info / warn / error
  format: console      # console（人类可读）/ json（结构化，生产环境推荐）
  output: stdout      # stdout / stderr / 文件路径 / 多输出用逗号分隔（如 "stdout,./logs/app.log"）
  file: logs/gopaw.log # 日志文件路径（系统日志页面需要）
