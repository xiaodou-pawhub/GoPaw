# ===========================================================================
# GoPaw 启动配置示例
# 复制此文件为 config.yaml，按需修改后启动服务。
#
# ⚠️  此文件只包含【系统启动配置】，不需要填写任何 API Key。
#     LLM 提供商、频道密钥、Agent 设定均通过 Web UI 配置（存储在 SQLite）。
# ===========================================================================

# ---------------------------------------------------------------------------
# 工作区目录
# 所有运行时数据（数据库、日志、技能、Agent 文件）都存放在此目录下。
# ---------------------------------------------------------------------------
workspace:
  dir: ~/.gopaw   # 支持 ~ 展开；Docker 部署填 /app/data

# ---------------------------------------------------------------------------
# 基础设置
# ---------------------------------------------------------------------------
app:
  name: "GoPaw"
  language: zh
  timezone: Asia/Shanghai
  admin_token: ""   # Web UI 访问密码；留空则每次启动自动生成并打印到日志

# ---------------------------------------------------------------------------
# HTTP 服务器
# ---------------------------------------------------------------------------
server:
  host: 0.0.0.0
  port: 8088

# ---------------------------------------------------------------------------
# Agent 行为参数
# Agent 的 System Prompt（角色设定）通过 Web UI → 设置 → Agent 配置
# ---------------------------------------------------------------------------
agent:
  max_steps: 20       # ReAct 循环最大步数（防止死循环）
  memory:
    context_limit: 20000   # Session 内估算 token 超过此值时触发记忆压缩
    history_limit: 50      # 每次调用最多取最近多少条消息作为上下文

# ---------------------------------------------------------------------------
# 日志配置
# 日志文件路径固定为 {workspace}/logs/gopaw.log，无需单独配置。
# ---------------------------------------------------------------------------
log:
  level: info     # debug / info / warn / error（debug 同时开启 Gin 详细日志）
  format: console # console（人类可读）/ json（结构化，生产环境推荐）
  output: stdout  # stdout（仅控制台）/ file（仅日志文件）/ both（两者）
