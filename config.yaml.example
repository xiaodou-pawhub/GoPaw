# ===========================================================================
# GoPaw 启动配置示例
# 复制此文件为 config.yaml，按需修改后启动服务。
#
# ⚠️  此文件只包含【系统启动配置】，不需要填写任何 API Key。
#     LLM 提供商、频道密钥、Agent 设定均通过 Web UI 配置（存储在 SQLite）。
# ===========================================================================

# ---------------------------------------------------------------------------
# 基础设置
# ---------------------------------------------------------------------------
app:
  # 应用名称（显示用）
  name: "GoPaw"
  # 界面语言（目前支持 zh）
  language: zh
  # 时区（影响定时任务和日志时间戳）
  timezone: Asia/Shanghai
  # 调试模式（true 时 Gin 显示详细路由，日志更详细）
  debug: false

# ---------------------------------------------------------------------------
# HTTP 服务器
# ---------------------------------------------------------------------------
server:
  host: 0.0.0.0
  port: 8088

# ---------------------------------------------------------------------------
# 数据存储
# ---------------------------------------------------------------------------
storage:
  # 目前仅支持 sqlite
  type: sqlite
  # 数据库文件路径（相对于工作目录）
  # data/AGENT.md 也会存放在同一目录下
  path: data/gopaw.db

# ---------------------------------------------------------------------------
# Agent 行为参数
# Agent 的 System Prompt（角色设定）通过 Web UI → 设置 → Agent 配置
# ---------------------------------------------------------------------------
agent:
  # ReAct 循环最大步数（防止死循环）
  max_steps: 20
  memory:
    # 当 Session 内估算 token 数超过此值时触发记忆压缩
    context_limit: 4000
    # 每次调用时最多取最近多少条消息作为上下文
    history_limit: 50

# ---------------------------------------------------------------------------
# 启用的频道插件列表
# 只有在此列表中的插件才会被加载，未启用的插件不消耗资源。
# 频道密钥（AppID/AppSecret 等）通过 Web UI → 设置 → 频道 配置。
# ---------------------------------------------------------------------------
plugins:
  enabled:
    - console      # Web Console（内置，建议始终启用）
    # - feishu     # 飞书机器人
    # - dingtalk   # 钉钉机器人
    # - webhook    # 通用 Webhook

# ---------------------------------------------------------------------------
# Skills 配置
# ---------------------------------------------------------------------------
skills:
  # 自定义 Skill 目录（相对于工作目录）
  dir: skills/
  # 要启用的 Skill 列表（留空则启用 dir 下所有已安装技能）
  enabled: []

# ---------------------------------------------------------------------------
# 日志配置
# ---------------------------------------------------------------------------
log:
  # 日志级别：debug / info / warn / error
  level: info
  # 格式：json（结构化）/ console（人类可读）
  format: json
  # 输出目标：stdout / file
  output: stdout
  # 当 output=file 时的日志文件路径
  file: logs/gopaw.log
